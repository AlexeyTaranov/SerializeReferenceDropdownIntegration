<idea-plugin>
    <id>com.jetbrains.rider.plugins.serializereferencedropdownintegration</id>
    <name>Serialize Reference Dropdown Integration</name>
    <version>2.0.1</version>
    <vendor url="https://github.com/AlexeyTaranov/SerializeReferenceDropdownIntegration">Author Alexey Taranov</vendor>
    <depends>com.intellij.modules.rider</depends>
    <description>
        <![CDATA[
        <p>Rider integration for Unity projects that use SerializeReference-heavy workflows.</p>
        <p>The plugin shows SerializeReference usage counts, helps update Unity YAML during class and namespace rename.</p>
        ]]>
    </description>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="tools.serialize.reference.dropdown"
                parentId="tools"
                displayName="Serialize Reference Dropdown"
                instance="com.jetbrains.rider.plugins.serializereferencedropdownintegration.SerializeReferenceDropdownConfigurable"/>
    </extensions>
</idea-plugin>
